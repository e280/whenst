		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "rm -rf x && mkdir x && tsc && scute -v",
		"dev": "octo 'tsc -w' 'node --watch x/tests.test.js' 'scute -wv' 'hottie x'",
		"test": "node x/tests.test.js",
